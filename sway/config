# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

# styles - set the folder for your theme definition file
set $theme /usr/share/sway/themes/matcha-green

# theme variables
include $theme/definitions

# global variables
include $HOME/.config/sway/etc/definitions

# user variables -> defines background etc
include $HOME/.config/sway/definitions.d/*.conf

include $HOME/.config/sway/etc/inputs/*
include $HOME/.config/sway/etc/outputs/*

# enable modes
include $HOME/.config/sway/etc/modes/*

# only enable this if every app you use is compatible with wayland
# xwayland disable

# include additional configs e.g. to autostart applications
include $HOME/.config/sway/etc/config.d/*

# okay so definitions get sourced before config.d, 
# which changes the background
# but we dont really want this shit background
# solution -- comment line in /etc/sway/config.d/90-enable-theme.conf

# user config
include $HOME/.config/sway/config.d/*.conf
# output eDP-1 background /home/jvidakovic/.config/sway/wallpaper.jpg fill
